{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"files.associations": {
			"*.yml": "ansible",
			"*.butane": "yaml"
		},
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "playbook-check",
				"type": "process",
				"command": "just",
				"args": [
					"playbook-check"
				],
				"problemMatcher": [],
				"group": {
					"kind": "test",
					"isDefault": true
				}
			},
			{
				"label": "playbook-check-verbose",
				"type": "process",
				"command": "just",
				"args": [
					"playbook-check-verbose"
				],
				"problemMatcher": [],
				"group": "test"
			},
			{
				"label": "playbook-verbose",
				"type": "process",
				"command": "just",
				"args": [
					"playbook-verbose"
				],
				"problemMatcher": [],
				"group": "build"
			},
			{
				"label": "playbook",
				"type": "process",
				"command": "just",
				"args": [
					"playbook"
				],
				"problemMatcher": [],
				"group": {
					"kind": "build",
					"isDefault": true
				}
			},
			{
				"label": "butane",
				"type": "process",
				"command": "just",
				"args": [
					"butane"
				],
				"problemMatcher": [],
				"group": "build"
			},
			{
				"label": "galaxy",
				"type": "process",
				"command": "just",
				"args": [
					"galaxy"
				],
				"problemMatcher": []
			},
			{
				"label": "ignition",
				"type": "process",
				"command": "just",
				"args": [
					"ignition"
				],
				"problemMatcher": []
			}
		]
	},
	"extensions": {
		"recommendations": [
			"redhat.vscode-yaml",
			"wholroyd.jinja",
			"redhat.ansible",
			"anthropic.claude-code",
			"github.vscode-github-actions"
		]
	}
}
