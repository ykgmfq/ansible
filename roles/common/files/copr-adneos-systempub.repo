[copr:copr.fedorainfracloud.org:adneos:systempub]
name=Copr repo for systempub owned by adneos
baseurl=https://download.copr.fedorainfracloud.org/results/adneos/systempub/fedora-$releasever-$basearch/
type=rpm-md
skip_if_unavailable=True
gpgcheck=1
gpgkey=https://download.copr.fedorainfracloud.org/results/adneos/systempub/pubkey.gpg
repo_gpgcheck=0
enabled=1
enabled_metadata=1
