#!/usr/bin/fish
set tag (basename (pwd))
set fedora 38
echo "Base Image  | $fedora"
echo "Tag         | $tag"
begin
    set ctr (buildah from --pull quay.io/fedora/fedora:$fedora)
    buildah config \
        --port 8096 \
        --cmd /usr/bin/jellyfin \
        $ctr
    buildah run $ctr /usr/bin/bash -c 'set -eu && \
curl --remote-name --output-dir /etc/yum.repos.d https://copr.fedorainfracloud.org/coprs/leo3418/jellyfin/repo/fedora-$(rpm -E %fedora)/leo3418-jellyfin-fedora-$(rpm -E %fedora).repo
dnf -y install https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm && \
dnf -y install --setopt=install_weak_deps=0 jellyfin && \
dnf clean all'; or false
    buildah commit --rm $ctr $tag
end
