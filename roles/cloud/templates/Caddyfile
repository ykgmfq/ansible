cloud.dm-poepperl.de {
  root * {{ html_dir }}
  file_server
  php_fastcgi unix/{{ php_socket }}
  # Mozilla Observatory B+, STS not working
  import stdheader
  encode zstd gzip
  @dav {
    path /.well-known/carddav
    path /.well-known/caldav
  }
  @forbidden {
    path    /.htaccess
    path    /data/
    path    /config/
    path    /db_structure
    path    /.xml
    path    /README
    path    /3rdparty/
    path    /lib/
    path    /templates/*
    path    /occ
    path    /console.php
  }
  respond @forbidden 404
  redir @dav /remote.php/dav permanent
}
