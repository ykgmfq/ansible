#!/usr/bin/fish
set tag (basename (pwd))
set fedora {{ versions.fedora }}
echo "Base Image  | $fedora"
echo "Tag         | $tag"
set ctr (buildah from --pull quay.io/fedora/fedora:$fedora)
and set script (cat install.sh | string collect)
and buildah config \
--port 8096 \
--cmd /usr/bin/jellyfin \
$ctr
and buildah run $ctr /usr/bin/bash -c $script
and buildah commit --rm $ctr $tag
or exit 1
