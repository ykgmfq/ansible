{% set icons = '/var/icons' %}
apiVersion: v1
kind: Pod
metadata:
  annotations:
    io.containers.autoupdate: registry
  labels:
    app: vault-pod
  name: vault-pod
spec:
  automountServiceAccountToken: false
  containers:
    - env:
        - name: TZ
          value: Europe/Berlin
        - name: ICON_CACHE_FOLDER
          value: {{ icons }}
        - name: ROCKET_PORT
          value: "{{ ports.vault }}"
        - name: LOG_LEVEL
          value: warn
        - name: DATABASE_URL
          value: postgresql://vault@localhost/vault
        - name: INVITATION_ORG_NAME
          value: Lauras and Dennis' Cloud
        - name: PASSWORD_HINTS_ALLOWED
          value: false
        - name: SIGNUPS_ALLOWED
          value: false
        - name: DOMAIN
          value: https://vault.dm-poepperl.de
        - name: IP_HEADER
          value: X-Forwarded-For
        - name: SMTP_HOST
          value: smtp.strato.de
        - name: SMTP_SECURITY
          value: force_tls
        - name: SMTP_PORT
          value: 465
        - name: SMTP_FROM
          value: cloud@dm-poepperl.de
        - name: SMTP_USERNAME
          value: cloud@dm-poepperl.de
        - name: SMTP_FROM_NAME
          value: L&D Cloud
        - name: SMTP_PASSWORD
          value: Yt58jcKyaMMxPbWYU9VQ
        - name: TRASH_AUTO_DELETE_DAYS
          value: 1000
      image: ghcr.io/dani-garcia/vaultwarden:alpine
      name: app
      ports:
        - name: vault
          containerPort: {{ ports.vault }}
          hostPort: {{ ports.vault }}
      resources: {}
      securityContext:
        runAsGroup: {{ users.vault }}
        runAsUser: {{ users.vault }}
      volumeMounts:
        - mountPath: /data
          name: vault-pvc
        - mountPath: {{ icons }}
          name: vault-icons-pvc
    - args:
        - postgres
      env:
        - name: POSTGRES_PASSWORD
          value: a
      image: docker.io/library/postgres:15-alpine
      name: db
      resources: {}
      volumeMounts:
        - mountPath: /var/lib/postgresql/data
          name: vault-db-pvc
  enableServiceLinks: false
  volumes:
    - name: vault-pvc
      persistentVolumeClaim:
        claimName: vault
    - name: vault-icons-pvc
      persistentVolumeClaim:
        claimName: vault-icons
    - name: vault-db-pvc
      persistentVolumeClaim:
        claimName: vault-db
