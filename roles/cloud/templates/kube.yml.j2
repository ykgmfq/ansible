---
apiVersion: v1
kind: Pod
metadata:
  annotations:
    io.containers.autoupdate/app: local
    io.containers.autoupdate/web: local
  labels:
    app: cloud-pod
  name: cloud-pod
spec:
  automountServiceAccountToken: false
  containers:
    - image: localhost/cloud-web:latest
      name: web
      ports:
        - name: web
          containerPort: 80
          hostPort: 8088
      securityContext:
        capabilities:
          drop:
            - CAP_MKNOD
            - CAP_NET_RAW
            - CAP_AUDIT_WRITE
      volumeMounts:
        - mountPath: /srv/de.dm-poepperl.cloud
          name: cloud-pvc
          readOnly: true
        - mountPath: /srv/de.dm-poepperl.cloud/data/appdata_och5khtk0i0u/preview
          name: cloud-preview-pvc
          readOnly: true
    - image: localhost/cloud:latest
      name: app
      securityContext:
        capabilities:
          drop:
            - CAP_MKNOD
            - CAP_NET_RAW
            - CAP_AUDIT_WRITE
      volumeMounts:
        - mountPath: /srv/de.dm-poepperl.cloud
          name: cloud-pvc
        - mountPath: /var/lib/pgsql/data
          name: cloud-db-pvc
        - mountPath: /srv/de.dm-poepperl.cloud/data/appdata_och5khtk0i0u/preview
          name: cloud-preview-pvc
  enableServiceLinks: false
  volumes:
{% for vols in volumes.values() %}
{% for vol in vols %}
    - name: {{ vol }}-pvc
      persistentVolumeClaim:
        claimName: {{ vol }}
{% endfor %}
{% endfor %}
